{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reality-rag/contracts/schemas/OpsAuditLog.schema.json",
  "title": "OpsAuditLog",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "audit_id": {
      "type": "string",
      "minLength": 1
    },
    "command_id": {
      "type": "string"
    },
    "trace_id": {
      "$ref": "./common.schema.json#/$defs/trace_id"
    },
    "idempotency_key": {
      "type": "string"
    },
    "actor_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "$ref": "./common.schema.json#/$defs/tenant_id"
    },
    "collection_id": {
      "$ref": "./common.schema.json#/$defs/collection_id"
    },
    "action": {
      "type": "string",
      "minLength": 1
    },
    "target_type": {
      "type": "string",
      "minLength": 1
    },
    "target_id": {
      "type": "string",
      "minLength": 1
    },
    "before_state": {
      "type": "string"
    },
    "after_state": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "payload_hash": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "audit_id",
    "actor_id",
    "action",
    "target_type",
    "target_id",
    "payload_hash",
    "created_at"
  ]
}
