{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reality-rag/contracts/schemas/IndexVersion.schema.json",
  "title": "IndexVersion",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "index_version_id": {
      "$ref": "./common.schema.json#/$defs/index_version_id"
    },
    "tenant_id": {
      "$ref": "./common.schema.json#/$defs/tenant_id"
    },
    "collection_id": {
      "$ref": "./common.schema.json#/$defs/collection_id"
    },
    "status": {
      "$ref": "./common.schema.json#/$defs/index_version_status"
    },
    "schema_version": {
      "type": "string"
    },
    "index_profile_id": {
      "$ref": "./common.schema.json#/$defs/profile_id"
    },
    "chunk_profile_id": {
      "$ref": "./common.schema.json#/$defs/profile_id"
    },
    "embedding_model": {
      "type": "string"
    },
    "opensearch_index": {
      "type": "string"
    },
    "qdrant_collection": {
      "type": "string"
    },
    "chunk_count": {
      "type": "integer",
      "minimum": 0
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "activated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "required": [
    "index_version_id",
    "tenant_id",
    "collection_id",
    "status",
    "schema_version",
    "index_profile_id",
    "chunk_profile_id",
    "embedding_model",
    "opensearch_index",
    "qdrant_collection",
    "chunk_count",
    "created_at",
    "activated_at"
  ]
