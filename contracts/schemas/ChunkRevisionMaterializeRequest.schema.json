{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reality-rag/contracts/schemas/ChunkRevisionMaterializeRequest.schema.json",
  "title": "ChunkRevisionMaterializeRequest",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "command_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "$ref": "./common.schema.json#/$defs/trace_id"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "$ref": "./common.schema.json#/$defs/tenant_id"
    },
    "collection_id": {
      "$ref": "./common.schema.json#/$defs/collection_id"
    },
    "target_type": {
      "type": "string",
      "enum": ["chunk_revision"]
    },
    "target_id": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reason": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "command_id",
    "trace_id",
    "idempotency_key",
    "actor",
    "tenant_id",
    "collection_id",
    "target_type",
    "target_id",
    "payload"
  ]
}
