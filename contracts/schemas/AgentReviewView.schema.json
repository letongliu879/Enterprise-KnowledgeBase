{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reality-rag/contracts/schemas/AgentReviewView.schema.json",
  "title": "AgentReviewView",
  "type": "object",
  "additionalProperties": false,
  "description": "Read-only view of AgentReview artifact. Workbench displays but does not modify.",
  "properties": {
    "ticket_id": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL",
        "REVIEW",
        "DEGRADED"
      ]
    },
    "quality_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "category": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "major",
              "minor",
              "info"
            ]
          },
          "message": {
            "type": "string"
          },
          "evidence_anchor": {
            "type": "string"
          }
        },
        "required": [
          "category",
          "severity",
          "message"
        ]
      }
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "flag_type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "required": [
          "flag_type",
          "description"
        ]
      }
    },
    "evidence_anchors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "anchor_id": {
            "type": "string"
          },
          "doc_id": {
            "type": "string"
          },
          "evidence_id": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "page_span": {
            "$ref": "./common.schema.json#/$defs/page_span"
          }
        },
        "required": [
          "anchor_id",
          "doc_id",
          "evidence_id"
        ]
      }
    },
    "model": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "prompt_hash": {
      "type": "string"
    },
    "suggested_fixes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "fix_type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "target_evidence_id": {
            "type": "string"
          }
        },
        "required": [
          "fix_type",
          "description"
        ]
      }
    },
    "degraded_reason": {
      "type": ["string", "null"]
    },
    "failure_reason": {
      "type": ["string", "null"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "ticket_id",
    "decision",
    "quality_findings",
    "risk_flags",
    "evidence_anchors",
    "suggested_fixes",
    "created_at"
  ]
}
