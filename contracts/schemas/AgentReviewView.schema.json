{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reality-rag/contracts/schemas/AgentReviewView.schema.json",
  "title": "AgentReviewView",
  "type": "object",
  "additionalProperties": false,
  "description": "Read-only view of agent review findings for approval/workbench display.",
  "properties": {
    "ticket_id": {
      "type": "string",
      "minLength": 1
    },
    "review_run_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_file_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "parse_snapshot_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "APPROVE",
        "REJECT",
        "QUARANTINE",
        "REVIEW",
        "REQUEST_CHANGES",
        "DEGRADED"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "finding_id": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "info"
            ]
          },
          "category": {
            "type": "string"
          },
          "problem_summary": {
            "type": "string",
            "minLength": 1
          },
          "source_quote": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidence_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "doc_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "source_file_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "parse_snapshot_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "page_from": {
            "type": [
              "integer",
              "null"
            ]
          },
          "page_to": {
            "type": [
              "integer",
              "null"
            ]
          },
          "state": {
            "type": "string",
            "enum": [
              "open",
              "resolved"
            ]
          },
          "confidence": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0,
            "maximum": 1
          }
        },
        "required": [
          "finding_id",
          "severity",
          "category",
          "problem_summary",
          "source_quote",
          "evidence_id",
          "doc_id",
          "source_file_id",
          "parse_snapshot_id",
          "page_from",
          "page_to",
          "state",
          "confidence"
        ]
      }
    },
    "matched_count": {
      "type": "integer",
      "minimum": 0
    },
    "unmatched_count": {
      "type": "integer",
      "minimum": 0
    },
    "model": {
      "type": [
        "string",
        "null"
      ]
    },
    "prompt_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": [
        "string",
        "null"
      ]
    },
    "prompt_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "artifact_schema_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "degraded_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "failure_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "ticket_id",
    "decision",
    "findings",
    "matched_count",
    "unmatched_count",
    "created_at"
  ]
}
