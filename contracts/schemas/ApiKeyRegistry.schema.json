{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reality-rag/contracts/schemas/ApiKeyRegistry.schema.json",
  "title": "ApiKeyRegistry",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "api_key_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "$ref": "./common.schema.json#/$defs/tenant_id"
    },
    "key_hash": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string"
    },
    "knowledge_scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "debug_permission": {
      "type": "boolean"
    },
    "token_budget_limit": {
      "type": "integer",
      "minimum": 1
    },
    "state": {
      "type": "string",
      "enum": [
        "active",
        "disabled",
        "revoked",
        "expired"
      ]
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_by": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_rotated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "api_key_id",
    "tenant_id",
    "key_hash",
    "display_name",
    "knowledge_scopes",
    "roles",
    "debug_permission",
    "token_budget_limit",
    "state",
    "created_by",
    "created_at",
    "updated_by",
    "updated_at"
  ]
}
