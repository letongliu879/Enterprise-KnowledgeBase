{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reality-rag/contracts/schemas/ApiKeyProjection.schema.json",
  "title": "ApiKeyProjection",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "api_key_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "$ref": "./common.schema.json#/$defs/tenant_id"
    },
    "agent_type_id": {
      "type": "string",
      "minLength": 1
    },
    "knowledge_scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "debug_permission": {
      "type": "boolean"
    },
    "token_budget_limit": {
      "type": "integer",
      "minimum": 1
    },
    "state": {
      "type": "string",
      "enum": [
        "active",
        "disabled",
        "revoked",
        "expired"
      ]
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "projection_version": {
      "type": "integer",
      "minimum": 1
    },
    "last_updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "api_key_id",
    "tenant_id",
    "agent_type_id",
    "knowledge_scopes",
    "roles",
    "debug_permission",
    "token_budget_limit",
    "state",
    "projection_version",
    "last_updated_at"
  ]
}
