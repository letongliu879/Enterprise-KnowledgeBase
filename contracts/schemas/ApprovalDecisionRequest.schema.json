{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reality-rag/contracts/schemas/ApprovalDecisionRequest.schema.json",
  "title": "ApprovalDecisionRequest",
  "type": "object",
  "additionalProperties": false,
  "description": "Request to decide an approval ticket. Owner: approval-service.",
  "properties": {
    "command_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "$ref": "./common.schema.json#/$defs/trace_id"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "$ref": "./common.schema.json#/$defs/tenant_id"
    },
    "collection_id": {
      "$ref": "./common.schema.json#/$defs/collection_id"
    },
    "target_type": {
      "type": "string",
      "enum": ["ticket"]
    },
    "target_id": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "string",
          "enum": ["approve", "reject", "return"]
        },
        "reason": {
          "type": ["string", "null"]
        }
      },
      "required": ["action"]
    }
  },
  "required": [
    "command_id",
    "trace_id",
    "idempotency_key",
    "actor",
    "tenant_id",
    "collection_id",
    "target_type",
    "target_id",
    "payload"
  ]
}
