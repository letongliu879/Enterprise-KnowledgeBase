{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reality-rag/contracts/schemas/AdminCollection.schema.json",
  "title": "AdminCollection",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "collection_id": {
      "$ref": "./common.schema.json#/$defs/collection_id"
    },
    "tenant_id": {
      "$ref": "./common.schema.json#/$defs/tenant_id"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "active",
        "archived",
        "disabled"
      ]
    },
    "authority_level": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10
    },
    "access_policy": {
      "type": "object"
    },
    "default_parser_profile_id": {
      "type": "string"
    },
    "default_retrieval_profile_id": {
      "type": "string"
    },
    "default_approval_policy_id": {
      "type": "string"
    },
    "created_by": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_by": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "collection_id",
    "tenant_id",
    "name",
    "lifecycle_state",
    "created_by",
    "created_at",
    "updated_by",
    "updated_at"
  ]
}
