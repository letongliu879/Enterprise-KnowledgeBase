# =============================================================================
# Enterprise KnowledgeBase — Deployment Environment Variables
# =============================================================================
# Copy to .env and fill in real values before deployment.
# This file is tracked; .env is gitignored.

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://rag_flow:CHANGE_ME@postgres:5432/rag_flow
DATABASE_USERNAME=rag_flow
DATABASE_PASSWORD=CHANGE_ME
DATABASE_DRIVER=org.postgresql.Driver

# --- OpenSearch ---
OPENSEARCH_BASE_URL=http://opensearch:9201
INDEXING_OPENSEARCH_URL=http://opensearch:9201

# --- Qdrant ---
QDRANT_BASE_URL=http://qdrant:6333
INDEXING_QDRANT_URL=http://qdrant:6333

# --- Redis ---
REDIS_URL=redis://:CHANGE_ME@redis:6379/0
REDIS_PASSWORD=CHANGE_ME

# --- MinIO / S3 Object Storage (not in current MVP path) ---
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME

# --- SiliconFlow API ---
INDEXING_EMBEDDING_API_KEY=CHANGE_ME
INDEXING_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1/embeddings
INDEXING_EMBEDDING_MODEL=BAAI/bge-m3
INDEXING_CHAT_API_KEY=CHANGE_ME
INDEXING_CHAT_BASE_URL=https://api.deepseek.com
INDEXING_CHAT_MODEL=deepseek-v4-flash

# --- DeepSeek Agent Review ---
# Required by intake-runtime agent reviewer (ingestion-worker, agent-review-worker).
DEEPSEEK_API_KEY=${INDEXING_CHAT_API_KEY}
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Indexing Backend ---
INDEXING_BACKEND_MODE=hybrid

# --- JWT Auth (smoke mode uses smoke-test-secret; production requires all 4) ---
AUTH_MODE=smoke
ADMIN_JWT_SECRET=CHANGE_ME
ADMIN_JWT_ISSUER=
ADMIN_JWT_AUDIENCE=
JWT_SECRET=CHANGE_ME
JWT_ISSUER=
JWT_AUDIENCE=

# --- Retrieval Backends ---
EMBEDDING_API_KEY=CHANGE_ME
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_API_KEY=CHANGE_ME
RERANKER_BASE_URL=https://api.siliconflow.cn/v1/rerank
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- Retrieval Cache ---
RETRIEVAL_CACHE_PROVIDER=noop

# --- Strict Mode Flags ---
REQUIRE_LIVE_BACKENDS=false
REQUIRE_REDIS_CACHE=false
INDEXING_REQUIRE_LIVE_BACKENDS=false

# --- Service Base URLs (for cross-service HTTP) ---
ADMIN_BASE_URL=http://admin:18084
INDEXING_BASE_URL=http://indexing:18080
INTAKE_BASE_URL=http://intake:18085
RETRIEVAL_BASE_URL=http://retrieval:18082
RETRIEVAL_SERVICE_URL=http://retrieval:18082
ACCESS_BASE_URL=http://access:18081
PUBLISHING_WORKER_BASE_URL=http://publishing:18086

# --- Intake Runtime ---
REALITY_RAG_INTAKE_RUNTIME_DIR=/data/intake
