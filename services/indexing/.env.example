# Enterprise KB Indexing Service Environment

# Chat / LLM model config (leave empty to disable live model calls)
INDEXING_CHAT_API_KEY=
INDEXING_CHAT_BASE_URL=
INDEXING_CHAT_MODEL=deepseek-chat

# Embedding model config (leave empty to disable live embedding)
INDEXING_EMBEDDING_API_KEY=
INDEXING_EMBEDDING_BASE_URL=
INDEXING_EMBEDDING_MODEL=BAAI/bge-m3
INDEXING_EMBEDDING_BATCH_SIZE=16

# Index backend mode: noop (default), opensearch, qdrant
INDEXING_BACKEND_MODE=noop

# External backend URLs (only used when backend mode is not noop)
INDEXING_OPENSEARCH_URL=http://opensearch:9200
INDEXING_QDRANT_URL=http://qdrant:6333

# Database (shared with other Python services via reality_rag_persistence)
DATABASE_URL=sqlite:///indexing.db
