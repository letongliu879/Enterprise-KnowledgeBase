# Reality-RAG Workbench API Environment

# JWT / Auth (must match admin secret for token validation)
JWT_SECRET=change-me-in-production

# Database (shared with admin and other Python services)
DATABASE_URL=sqlite:///workbench.db

# Downstream service URLs
ADMIN_BASE_URL=http://127.0.0.1:18084
INDEXING_BASE_URL=http://127.0.0.1:18080
INTAKE_BASE_URL=http://127.0.0.1:18085
