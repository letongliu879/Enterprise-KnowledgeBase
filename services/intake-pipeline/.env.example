# Reality-RAG Intake Pipeline Environment

# Indexing service URL (used to call parse-preview and index-jobs)
REALITY_RAG_INDEXING_BASE_URL=http://127.0.0.1:18080

# Runtime directory for intake assets (source files, metadata, etc.)
REALITY_RAG_INTAKE_RUNTIME_DIR=.verify/runtime/intake

# Database (shared with other Python services)
DATABASE_URL=sqlite:///intake.db
