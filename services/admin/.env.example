# Reality-RAG Admin Service Environment

# JWT / Auth
ADMIN_JWT_SECRET=change-me-in-production
ADMIN_JWT_EXPIRATION_HOURS=24
ADMIN_SESSION_EXPIRATION_HOURS=168

# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:///admin.db

# Downstream service URLs
INDEXING_BASE_URL=http://127.0.0.1:18080
RETRIEVAL_BASE_URL=http://127.0.0.1:18082
ACCESS_BASE_URL=http://127.0.0.1:18081
PUBLISHING_WORKER_BASE_URL=http://127.0.0.1:18085

# Intake URL (for document ops that call intake)
INTAKE_BASE_URL=http://127.0.0.1:18085
